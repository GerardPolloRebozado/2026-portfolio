---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";
import { useTranslations } from "../i18n/ui";

interface Props {
    posts: CollectionEntry<"blog">[];
    currentPage: number;
    totalPages: number;
    prevUrl: string | undefined;
    nextUrl: string | undefined;
    lang: "en" | "es";
}

const { posts, currentPage, totalPages, prevUrl, nextUrl, lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="blog-inner">
    <div class="sep">
        <span class="sep-label"
            >Blog {totalPages > 1 ? `— ${currentPage}` : ""}</span
        >
        <span class="sep-rule"></span>
    </div>
    <ol class="post-list">
        {
            posts.map((post, i: number) => {
                const slug = post.id
                    .split("/")
                    .slice(1)
                    .join("/")
                    .replace(/\.[^/.]+$/, "");
                const postNum = (currentPage - 1) * 5 + i + 1; // Assuming pageSize 5
                return (
                    <li class="post-row">
                        <span class="post-num">
                            {String(postNum).padStart(2, "0")}
                        </span>
                        <a href={`/${lang}/blog/${slug}/`} class="post-title">
                            <span class="post-title">
                                <div class="post-body">{post.data.title}</div>
                                {post.data.description && (
                                    <p class="post-excerpt">
                                        {post.data.description}
                                    </p>
                                )}
                            </span>
                        </a>
                        <span class="post-date">
                            <FormattedDate date={post.data.pubDate} />
                        </span>
                    </li>
                );
            })
        }
    </ol>
    {posts.length === 0 && <p>{t("blog.no_posts")}</p>}

    {
        totalPages > 1 && (
            <div class="pagination">
                {prevUrl ? (
                    <a href={prevUrl} class="prev">
                        {t("blog.prev")}
                    </a>
                ) : (
                    <span class="prev disabled">{t("blog.prev")}</span>
                )}

                <span class="page-count">
                    {currentPage} / {totalPages}
                </span>

                {nextUrl ? (
                    <a href={nextUrl} class="next">
                        {t("blog.next")}
                    </a>
                ) : (
                    <span class="next disabled">{t("blog.next")}</span>
                )}
            </div>
        )
    }
</div>

<style>
    .blog-inner {
        max-width: 860px;
        margin: 1rem auto;
        padding: 6rem 2rem;
    }
    .post-list {
        list-style: none;
        padding: 0;
        margin: 2rem 0 0;
    }

    .post-row {
        display: grid;
        grid-template-columns: 2.5rem 1fr auto;
        align-items: start;
        gap: 0 1.5rem;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--rule);
    }

    .post-num {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--ink3);
        padding-top: 0.2rem;
    }

    .post-title {
        font-family: var(--font-display);
        font-size: 1.1rem;
        color: var(--ink);
        text-decoration: none;
        line-height: 1.3;
    }
    .post-title:hover {
        color: var(--blue);
    }

    .post-excerpt {
        font-size: 0.85rem;
        color: var(--ink2);
        margin: 0.3rem 0 0;
        line-height: 1.6;
    }

    .post-date {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--ink3);
        white-space: nowrap;
        padding-top: 0.3rem;
    }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        margin-top: 3rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
    }

    .pagination a {
        color: var(--blue);
        text-decoration: none;
    }

    .pagination .disabled {
        color: var(--ink3);
        opacity: 0.5;
    }

    .page-count {
        color: var(--ink2);
    }

    @media (max-width: 640px) {
        .post-row {
            grid-template-columns: 1fr;
            gap: 0.2rem;
        }
        .post-date {
            display: none;
        }
        .blog-inner {
            padding: 4rem 1.5rem;
        }
    }
</style>
