---
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<div id="container">
    <h1 class="text-center">Projects</h1>
    <div id="projects">
        {
            projects.map((project, index) => (
                <div class="project-card">
                    <div class="marquee-container" aria-hidden="true">
                        <div class="marquee-track">
                            <span class="marquee-text">
                                {project.data.title} &nbsp;&nbsp;&nbsp;
                                {project.data.title} &nbsp;&nbsp;&nbsp;
                            </span>
                        </div>
                    </div>
                    <div class="card-content">
                        <h2>{project.data.title}</h2>
                        <img
                            src={project.data.heroImage}
                            alt={project.data.title + " hero image"}
                        />
                        <p>{project.data.description}</p>
                        {project.data.url && (
                            <a href={project.data.url} class="button">
                                Visit Project
                            </a>
                        )}
                    </div>
                </div>
            ))
        }
    </div>
</div>

<style>
    #hero {
        max-width: 600px;
        margin: 4em auto;
        padding: 0 1em;
        min-height: 90dvh;
        text-align: center;
    }

    #container {
        background: var(--bg-surface);
        width: 100%;
        border-radius: var(--border-radius);
        padding: 2rem 0 50vh 0;
    }

    #projects {
        display: flex;
        flex-direction: column;
        gap: 10em;
        margin: 1em 0;

        & > .project-card:first-child .card-content {
            transform-origin: top center;
            animation: rotateCardIn linear forwards;
            animation-timeline: view();
            animation-range: entry;
        }
    }

    .project-card {
        border-radius: var(--border-radius);
        background: var(--bg-main) no-repeat;
        margin: 0 2em;

        position: sticky;
        top: 5vh;

        height: 90dvh;
        display: flex;
        align-items: center;
        justify-content: center;

        perspective: 1200px;

        transform-origin: top center;
        animation: rotateCardAway linear both;
        animation-timeline: view();
        animation-range: exit;
    }

    @keyframes rotateCardAway {
        0% {
            transform: scale(1) rotateX(0deg);
            opacity: 1;
            filter: blur(0px);
        }
        100% {
            transform: scale(0.8) rotateX(-45deg) translateY(-10%);
            opacity: 0;
            filter: blur(10px);
            visibility: hidden;
        }
    }

    @keyframes rotateCardIn {
        0% {
            transform: scale(0.5) rotateX(-45deg) translateY(-10%);
            opacity: 0;
            filter: blur(10px);
        }
        100% {
            transform: scale(1) rotateX(0deg);
            opacity: 1;
            filter: blur(0px);
        }
    }

    .card-content {
        position: relative;
        z-index: 2;
        background: var(--bg-main);
        padding: 2em;
        border-radius: 8px;
        text-align: center;
        max-width: 50%;
        border: 1px solid var(--bg-surface);
    }

    /* Fallback for Safari and Firefox */
    @supports not (animation-timeline: view()) {
        .project-card,
        .card-content {
            animation: none !important;
            opacity: 1 !important;
            transform: none !important;
            filter: none !important;
            visibility: visible !important;
        }
    }

    .card-content img {
        width: 35rem;
        max-width: 100%;
        border-radius: 12px;
        margin: 1em 0;
    }

    .marquee-container {
        position: absolute;
        top: 50%;
        left: 0;
        transform: translateY(-50%);
        width: 100%;
        overflow: hidden;
        white-space: nowrap;
        z-index: 0;
        pointer-events: none;
        opacity: 0.1;
    }

    .marquee-track {
        display: inline-flex;
        animation: scrollText 12s linear infinite;
    }

    .marquee-text {
        font-size: 8rem;
        font-weight: 900;
        text-transform: uppercase;
        padding-right: 2rem;
    }

    @keyframes scrollText {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }
</style>

<script>
    const tracks = document.querySelectorAll(".marquee-track");

    tracks.forEach((track) => {
        const clone = track.innerHTML;
        track.innerHTML += clone;
    });
</script>
