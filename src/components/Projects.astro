---
const projects = [
    {
        data: {
            title: "Assessors Dupre",
            url: "https://assessorsdupre.com/",
            description:
                "Landing page for an insurance broker, featuring a clean design and responsive layout. Showcases the company's services and expertise to attract potential clients.",
            tags: ["astro", "tailwind", "landing page", "rybbit"],
            pubDate: new Date("2024-02-15"),
        },
    },
    {
        data: {
            title: "De La Granja A Casa",
            url: "https://dlagranjaacasa.com/",
            description:
                "Dlagranja a Casa is an ecommerce platform where supermarkets can order dairy products directly from their supplier, it features a range of products and a user-friendly interface for easy ordering.",
            tags: ["next.js", "payload cms", "ecommerce", "heroui"],
            pubDate: new Date("2023-08-01"),
        },
    },
    {
        data: {
            title: "Social To Mealie",
            url: "https://github.com/username/social-to-mealie",
            description:
                "Imports social platforms content to Mealie for recipe saving using AI.",
            tags: [
                "ai",
                "next.js",
                "shadcn/ui",
                "Apple Shortcuts",
                "yt-dlp",
                "gallery-dl",
                "open source",
            ],
            pubDate: new Date("2025-03-10"),
        },
    },
    {
        data: {
            title: "Navifetch",
            url: "https://github.com/GerardPolloRebozado/navifetch",
            description:
                "A navidrome proxy that adds support for importing songs from YouTube using yt-dlp, allowing users to easily expand their music library with tracks from YouTube while still enjoying the features of Navidrome.",
            tags: ["go", "navidrome", "yt-dlp", "open source", "musicbrainz"],
            pubDate: new Date("2026-3-5"),
        },
    },
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="projects">
    <div class="proj-inner">
        <div class="sep fade-up">
            <span class="sep-num">03 —</span>
            <span class="sep-label">Projects</span>
            <span class="sep-rule"></span>
        </div>
        <div class="proj-list fade-up">
            {
                projects.map((project) => (
                    <div class="card">
                        <div class="card-top">
                            <span class="card-path">
                                ~/
                                {project.data.title
                                    .toLowerCase()
                                    .replace(/\s+/g, "-")}
                            </span>
                            {project.data.url && (
                                <a
                                    href={project.data.url}
                                    target="_blank"
                                    class="card-link"
                                >
                                    {project.data.url.includes("github.com")
                                        ? "github ↗"
                                        : "visit ↗"}
                                </a>
                            )}
                        </div>
                        <h3 class="card-title">{project.data.title}</h3>
                        <p class="card-desc">{project.data.description}</p>
                        {project.data.tags && (
                            <div class="card-tags">
                                {project.data.tags.map((tag: string) => (
                                    <span class="chip">{tag}</span>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    #projects {
        padding: 6rem 2.5rem;
        background: var(--paper);
    }
    .proj-inner {
        max-width: 1400px;
        margin: 0 auto;
    }
    .proj-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }
    .card-path {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--ink3);
    }
    .card-link {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--blue);
        text-decoration: none;
    }
    .card-link:hover {
        text-decoration: underline;
    }
    .card-title {
        font-family: var(--font-display);
        font-size: 1.3rem;
        color: var(--ink);
        margin: 0 0 0.6rem;
        line-height: 1.2;
    }
    .card-desc {
        font-size: 0.875rem;
        line-height: 1.7;
        color: var(--ink2);
        margin: 0 0 1rem;
        flex: 1;
    }
    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: auto;
    }

    @media (max-width: 640px) {
        .proj-list {
            grid-template-columns: 1fr;
        }
        #projects {
            padding: 4rem 1.5rem;
        }
    }
</style>
