---
import { getCollection } from "astro:content";
import { useTranslations } from "../i18n/ui";

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "es");

const projectEntries = await getCollection("projects", ({ id }) => {
    return id.startsWith(`${lang}/`);
});

const projects = projectEntries
    .map((entry) => entry.data)
    .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<section id="projects">
    <div class="proj-inner">
        <div class="sep fade-up">
            <span class="sep-num">03 —</span>
            <span class="sep-label">{t("projects.title")}</span>
            <span class="sep-rule"></span>
        </div>
        <div class="proj-list fade-up">
            {
                projects.map((project) => (
                    <div class="card">
                        <div class="card-top">
                            <span class="card-path">
                                ~/
                                {project.title.toLowerCase().replace(/\s+/g, "-")}
                            </span>
                            {project.url && (
                                <a
                                    href={project.url}
                                    target="_blank"
                                    class="card-link"
                                >
                                    {project.url.includes("github.com")
                                        ? t("projects.github")
                                        : t("projects.visit")}
                                </a>
                            )}
                        </div>
                        <h3 class="card-title">{project.title}</h3>
                        <p class="card-desc">{project.description}</p>
                        {project.tags && (
                            <div class="card-tags">
                                {project.tags.map((tag: string) => (
                                    <span class="chip">{tag}</span>
                                ))}
                            </div>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    #projects {
        padding: 6rem 2.5rem;
        background: var(--paper);
    }
    .proj-inner {
        max-width: 1400px;
        margin: 0 auto;
    }
    .proj-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }
    .card-path {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--ink3);
    }
    .card-link {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--blue);
        text-decoration: none;
    }
    .card-link:hover {
        text-decoration: underline;
    }
    .card-title {
        font-family: var(--font-display);
        font-size: 1.3rem;
        color: var(--ink);
        margin: 0 0 0.6rem;
        line-height: 1.2;
    }
    .card-desc {
        font-size: 0.875rem;
        line-height: 1.7;
        color: var(--ink2);
        margin: 0 0 1rem;
        flex: 1;
    }
    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: auto;
    }

    @media (max-width: 640px) {
        .proj-list {
            grid-template-columns: 1fr;
        }
        #projects {
            padding: 4rem 1.5rem;
        }
    }
</style>
