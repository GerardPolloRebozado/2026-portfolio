---
import { skills } from "../contants";
import { useTranslations } from "../i18n/ui";
import Phrases from "./Phrases.astro";

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "es");
---

<section id="about">
    <div class="about-inner">
        <div class="sep fade-up">
            <span class="sep-num">01 —</span>
            <span class="sep-label">{t("about.title")}</span>
            <span class="sep-rule"></span>
        </div>

        <div class="about-grid">
            <!-- Bio -->
            <div class="about-bio fade-up">
                <p>
                    {t("about.p1")}
                </p>
                <!-- <Phrases /> -->
                <p set:html={t("about.p2")} />
                <p>
                    {t("about.p3")}
                </p>
            </div>

            <!-- Sidebar -->
            <div class="about-sidebar fade-up" style="animation-delay:0.1s">
                <div class="sidebar-block">
                    <p class="sidebar-label">{t("about.stack")}</p>
                    <div class="chips-wrap">
                        {
                            skills.map((skill) => (
                                <span class="chip">{skill}</span>
                            ))
                        }
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">{t("about.now")}</p>
                    <div class="now-list">
                        <div class="now-item">
                            <span class="now-arrow">→</span>
                            <span>{t("about.now_item1")}</span>
                        </div>
                        <div class="now-item">
                            <span class="now-arrow">→</span>
                            <span>{t("about.now_item2")}</span>
                        </div>
                        <div class="now-item">
                            <span class="now-arrow">→</span>
                            <span set:html={t("about.now_item3")} />
                        </div>
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">{t("about.misc")}</p>
                    <div class="misc-list">
                        <div class="misc-row">
                            <span class="misc-key">{t("about.editor")}</span>
                            <span class="misc-sep">·</span>
                            <span class="misc-val">JetBrains + IdeaVim</span>
                        </div>
                        <div class="misc-row">
                            <span class="misc-key">{t("about.os")}</span>
                            <span class="misc-sep">·</span>
                            <span class="misc-val">I use arch btw</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    #about {
        padding: 6rem 2.5rem;
        background: var(--paper);
    }

    .about-inner {
        max-width: 1200px;
        margin: 0 auto;
    }

    .about-grid {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: 4rem;
    }

    @media (max-width: 900px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        #about {
            padding: 4rem 1.5rem;
        }
    }

    .about-bio {
        font-size: 0.95rem;
        line-height: 1.85;
        color: var(--ink2);
    }
    .about-bio p {
        margin-bottom: 1.25rem;
    }

    .chips-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .sidebar-block {
        margin-bottom: 1.75rem;
        padding-bottom: 1.75rem;
        border-bottom: 1px solid var(--rule);
    }
    .sidebar-block:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .sidebar-label {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink3);
        margin: 0 0 0.75rem;
    }

    .now-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .now-item {
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
        font-size: 0.88rem;
        color: var(--ink2);
    }

    .now-arrow {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--blue);
        margin-top: 0.1rem;
        flex-shrink: 0;
    }

    .misc-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .misc-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
    }
    .misc-key {
        color: var(--ink3);
    }
    .misc-sep {
        color: var(--rule);
    }
    .misc-val {
        color: var(--ink2);
    }
</style>
