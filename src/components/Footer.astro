---
import SocialLinks from "./Social-links.astro";
import { useTranslations } from "../i18n/ui";

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "es");

const year = new Date().getFullYear();
---

<footer>
    <div class="foot-inner">
        <span class="foot-copy"
            >{t("footer.copy").replace("{year}", year.toString())}</span
        >
        <SocialLinks />
        <a
            href="https://rybbit.pollorebozado.com/6/main?timeMode=day&bucket=hour&stat=users&wellKnown=today"
            >{t("footer.analytics")}</a
        >
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--rule);
        background: var(--paper);
        padding: 2rem 2.5rem;
    }
    .foot-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem 2rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--ink3);
    }
    .foot-links {
        display: flex;
        gap: 1.5rem;
    }
    .foot-links a {
        color: var(--ink3);
        text-decoration: none;
        transition: color 0.2s;
    }
    .foot-links a:hover {
        color: var(--ink);
    }
    @media (max-width: 640px) {
        .foot-inner {
            flex-direction: column;
            text-align: center;
        }
        footer {
            padding: 1.5rem;
        }
    }
</style>
