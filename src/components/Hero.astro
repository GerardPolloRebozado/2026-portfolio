---
import { Mail } from "@lucide/astro";
import Github from "./icons/github.astro";
import Linkedin from "./icons/linkedin.astro";
---

<div id="hero">
    <div>
        <div>
            <h1 id="hello" class="animate-reveal-center">&lt; Hello /&gt;</h1>

            <img
                src="https://assets.gerarddupre.dev/profile.jpg"
                alt="Profile picture of Gerard Du Pre"
                id="small-me"
            />
        </div>
        <p class="justify animate-fade" id="about-me">
            I'm Gerard Du Pre, a software developer who enjoys building and
            running software that makes life easier. I'm especially into
            self-hosting, where I get to combine my coding skills with server
            management and automation.
            <br />
            <br />
            I've worked with a range of technologies, from C and Go to JavaScript,
            TypeScript, and Next.js, and I like learning new tools that help me solve
            problems more efficiently.
        </p>
        <div title="Contact icons" id="contact-buttons">
            <a
                href="mailto:hello@gerarddupre.dev"
                target="_blank"
                rel="noopener noreferrer"
                class="icon-button"
                ><Mail />
            </a>
            <a
                href="https://github.com/GerardPolloRebozado"
                target="_blank"
                rel="noopener noreferrer"
                class="icon-button"
            >
                <Github />
            </a>
            <a
                href="https://www.linkedin.com/in/gerard-du-pre/"
                target="_blank"
                rel="noopener noreferrer"
                class="icon-button"
            >
                <Linkedin />
            </a>
        </div>
    </div>
    <img
        src="https://assets.gerarddupre.dev/profile.jpg"
        alt="Profile picture of Gerard Du Pre"
        id="big-me"
        class="animate-fade"
    />
</div>

<style>
    #hero {
        padding: 10rem 0px 0px 0px;
        min-height: 90dvh;
        display: grid;
        grid-template-columns: auto auto;
        gap: 2rem;
        justify-content: space-evenly;
    }

    #contact-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;

        #contact-buttons > svg {
            color: var(--text-primary);
        }
    }

    #about-me {
        max-width: 600px;
    }

    @media (min-width: 768px) {
        #small-me {
            display: none;
        }
        #big-me {
            display: block;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            object-fit: cover;
        }
    }

    @media (max-width: 767px) {
        #hero {
            grid-template-columns: 1fr;
            text-align: center;
        }

        #hello {
            display: inline-block;
        }
        #small-me {
            display: inline-block;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 1em;
            vertical-align: middle;
        }
        #big-me {
            display: none;
        }
    }

    #hello {
        display: inline-block;
        margin-bottom: 0.5rem;
    }
</style>
