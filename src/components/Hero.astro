---
import GitHistory from "./github-history.astro";
import SocialLinks from "./Social-links.astro";

const skills = [
    "TypeScript",
    "React",
    "Next.js",
    "Node.js",
    "PostgreSQL",
    "Docker",
    "self-hosting",
    "open source",
    "Linux",
    "Astro",
    "C",
    "C++",
    "Go",
    "Git",
    "CSS",
    "Tailwind",
    "Vim",
    "Jetbrains",
    "Cloudflare",
    "Payload CMS",
];
---

<section id="hero">
    <!-- Marquee stripe -->
    <div class="marquee-stripe">
        <div class="marquee-inner">
            <span class="marquee-set">
                {
                    skills.map((skill) => (
                        <>
                            <span>{skill}</span>
                            <span class="mdot">·</span>
                        </>
                    ))
                }
            </span>
            <span class="marquee-set" aria-hidden="true">
                {
                    skills.map((skill) => (
                        <>
                            <span>{skill}</span>
                            <span class="mdot">·</span>
                        </>
                    ))
                }
            </span>
        </div>
    </div>
    <div class="hero-inner">
        <div class="hero-grid">
            <!-- Left: name -->
            <div class="hero-left">
                <h1 class="hero-name fade-up show">
                    Gerard<br /><em>Du Pre</em>
                </h1>
            </div>

            <!-- Right: bio, git log, CTAs -->
            <div class="hero-right fade-up show" style="animation-delay:0.08s">
                <p class="hero-bio">
                    Fullstack engineer —
                    <span style="color:var(--blue)"
                        >building things that work.</span
                    ><br />
                    I enjoy self-hosting, open source, and software that makes life
                    a easier. Based in Spain.
                </p>
                <GitHistory />
                <div class="hero-ctas">
                    <a href="#projects" class="cta-primary">see work →</a>
                    <a href="/blog" class="cta-secondary">read writing</a>
                </div>
            </div>
        </div>

        <div class="hero-footer">
            <SocialLinks />
            <p class="hero-loc">2026 · Spain</p>
        </div>
    </div>

    <style>
        #hero {
            min-height: 100svh;
            display: flex;
            flex-direction: column;
        }

        .marquee-stripe {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            overflow: hidden;
            border-bottom: 1px solid var(--rule);
            padding: 0.4rem 0;
            z-index: 1;
        }

        .marquee-inner {
            display: flex;
            animation: marquee 28s linear infinite;
            white-space: nowrap;
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--ink3);
            gap: 2rem;
        }

        .marquee-inner:hover {
            animation-play-state: paused;
        }

        .marquee-set {
            display: inline-flex;
            gap: 1.25rem;
            padding-right: 2rem;
        }

        .mdot {
            color: var(--blue);
        }

        .hero-inner {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            max-width: 1300px;
            margin: 0 auto;
            width: 100%;
            padding: 10rem 2.5rem 4rem;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: flex-end;
            margin-bottom: 3.5rem;
        }

        @media (max-width: 768px) {
            .hero-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .hero-inner {
                padding: 6rem 1.5rem 3rem;
            }
        }

        .hero-left {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .hero-name {
            font-family: var(--font-display);
            font-size: clamp(4rem, 11vw, 9rem);
            line-height: 0.92;
            letter-spacing: -0.02em;
            color: var(--ink);
            margin: 0;
        }

        .hero-right {
            padding-bottom: 0.5rem;
        }

        .hero-bio {
            font-size: 0.95rem;
            line-height: 1.75;
            color: var(--ink2);
            margin-bottom: 1.25rem;
        }

        .hero-ctas {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .cta-primary {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            padding: 0.55rem 1.25rem;
            background: var(--blue);
            color: #fff;
            border-radius: 2px;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .cta-primary:hover {
            opacity: 0.8;
        }

        .cta-secondary {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            padding: 0.55rem 1.25rem;
            border: 1px solid var(--rule);
            color: var(--ink2);
            border-radius: 2px;
            text-decoration: none;
            transition: opacity 0.2s;
        }
        .cta-secondary:hover {
            opacity: 0.7;
        }

        .hero-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--rule);
        }

        .hero-loc {
            font-family: var(--font-mono);
            font-size: 0.72rem;
            color: var(--ink3);
            margin: 0;
        }
    </style>
</section>
