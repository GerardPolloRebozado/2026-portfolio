---
import { getCollection } from "astro:content";
import { useTranslations } from "../i18n/ui";

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "es");

const experienceEntries = await getCollection("experience", ({ id }) => {
    return id.startsWith(`${lang}/`);
});

const experiences = experienceEntries
    .map((entry) => entry.data)
    .sort((a, b) => (a.order || 0) - (b.order || 0));
---

<section id="experience">
    <div class="exp-inner">
        <div class="sep fade-up">
            <span class="sep-num">02 —</span>
            <span class="sep-label">{t("experience.title")}</span>
            <span class="sep-rule"></span>
        </div>
        <div class="exp-list fade-up">
            {
                experiences.map((exp) => (
                    <div class="exp-item">
                        <div class="exp-year">{exp.period}</div>
                        <div class="exp-content">
                            <div class="exp-header">
                                <h3 class="exp-role">{exp.role}</h3>
                                {exp.current && (
                                    <span class="exp-badge">
                                        {t("experience.current")}
                                    </span>
                                )}
                            </div>
                            <p class="exp-company">
                                {exp.company} · {exp.location}
                            </p>
                            <p class="exp-desc">{exp.description}</p>
                            <div class="exp-tags">
                                {exp.tags?.map((tag) => (
                                    <span class="chip">{tag}</span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    #experience {
        padding: 6rem 2.5rem;
        background: var(--paper2);
    }
    .exp-inner {
        max-width: 1200px;
        margin: 0 auto;
    }
    .exp-list {
        display: flex;
        flex-direction: column;
    }

    .exp-item {
        display: grid;
        grid-template-columns: 6rem 1fr;
        gap: 0 1.5rem;
        padding: 1.75rem 0;
        border-bottom: 1px solid var(--rule);
    }
    .exp-item:last-child {
        border-bottom: none;
    }

    @media (max-width: 640px) {
        .exp-item {
            grid-template-columns: 1fr;
            gap: 0.25rem;
        }
        #experience {
            padding: 4rem 1.5rem;
        }
    }

    .exp-year {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--ink3);
        padding-top: 0.25rem;
        line-height: 1.6;
        white-space: pre-line;
    }

    .exp-header {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 0.25rem;
    }

    .exp-role {
        font-family: var(--font-display);
        font-size: 1.25rem;
        color: var(--ink);
        margin: 0;
        line-height: 1.2;
    }

    .exp-badge {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--blue);
        border: 1px solid var(--blue);
        border-radius: 2px;
        padding: 1px 6px;
        background: var(--bluefaint);
        letter-spacing: 0.05em;
    }

    .exp-company {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--ink3);
        margin: 0 0 0.75rem;
    }
    .exp-desc {
        font-size: 0.9rem;
        line-height: 1.75;
        color: var(--ink2);
        margin: 0 0 1rem;
    }
    .exp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }
</style>
