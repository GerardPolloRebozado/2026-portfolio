---
const services = [
    {
        number: "01",
        tech: "TYPESCRIPT · REACT · NEXT.JS",
        title: "Frontend Development",
        description:
            "Building modern, responsive and performant user interfaces using React, Next.js, and the latest web technologies.",
        icon: "⚛️",
    },
    {
        number: "02",
        tech: "NODE · GO · DOCKER",
        title: "Backend & DevOps",
        description:
            "Developing scalable backend services and automating infrastructure with Docker, CI/CD, and modern deployment practices.",
        icon: "🐳",
    },
    {
        number: "03",
        tech: "HOMELAB · SELF-HOSTING",
        title: "Systems & Infrastructure",
        description:
            "Managing self-hosted services, server infrastructure, and home lab setups for optimal performance and automation.",
        icon: "🖥️",
    },
];
---

<section id="services">
    <div class="section-header">
        <span class="system-label"
            >SYS://SERVICES {services.length} ENTRIES</span
        >
    </div>
    <h2 class="section-title">SERVICES</h2>
    <div class="services-grid">
        {
            services.map((service) => (
                <div class="service-card">
                    <div class="card-header">
                        <div class="number-and-icon">
                            <div class="service-number">{service.number}</div>
                            <div class="service-icon">{service.icon}</div>
                        </div>
                        <div class="service-tech">{service.tech}</div>
                    </div>
                    <div class="card-divider" />
                    <div class="card-content">
                        <h3 class="service-title">{service.title}</h3>
                        <p class="service-description">{service.description}</p>
                    </div>
                </div>
            ))
        }
    </div>
    <div class="section-footer">
        <span class="system-label">END OF INDEX</span>
    </div>
</section>

<style>
    #services {
        max-width: 1400px;
        margin: 0 auto;
        padding: 8rem 2rem;
    }

    .section-header {
        margin-bottom: 1rem;
    }

    .system-label {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.3);
        font-family: monospace;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 4rem;
        color: var(--text-primary, #fff);
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .service-card {
        position: relative;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 0.5rem;
        padding: 3rem 2rem 2rem;
        background: rgba(255, 255, 255, 0.02);
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .service-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border: 1px solid rgba(255, 255, 255, 0);
        border-radius: 0.5rem;
        transition: border-color 0.3s ease;
        pointer-events: none;
    }

    .service-card:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.25);
    }

    .service-card:hover::before {
        border-color: rgba(255, 255, 255, 0.2);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
        gap: 1rem;
    }

    .number-and-icon {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .service-number {
        font-size: 2.5rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.1);
        line-height: 1;
    }

    .service-icon {
        font-size: 2rem;
    }

    .service-tech {
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 600;
        text-align: right;
        line-height: 1.4;
        flex-shrink: 0;
    }

    .card-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin-bottom: 1.5rem;
    }

    .card-content {
        position: relative;
        z-index: 2;
    }

    .service-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--text-primary, #fff);
        margin: 0 0 1rem 0;
    }

    .service-description {
        font-size: 0.95rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    .section-footer {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    @media (max-width: 768px) {
        #services {
            padding: 4rem 1.5rem;
        }

        .services-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .section-title {
            font-size: 1.5rem;
            margin-bottom: 2rem;
        }

        .service-card {
            padding: 2rem 1.5rem 1.5rem;
        }

        .service-number {
            font-size: 2rem;
        }

        .service-icon {
            font-size: 1.5rem;
        }

        .service-tech {
            font-size: 0.6rem;
        }
    }
</style>
