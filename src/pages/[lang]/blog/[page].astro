---
import { getCollection, type CollectionEntry } from "astro:content";
import type { Page, PaginateFunction } from "astro";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import BlogList from "../../../components/BlogList.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../../consts";

export async function getStaticPaths({
    paginate,
}: {
    paginate: PaginateFunction;
}) {
    const languages = ["en", "es"] as const;
    const allPosts = await getCollection("blog");

    return languages.flatMap((lang) => {
        const filteredPosts = allPosts
            .filter((post) => post.id.startsWith(`${lang}/`))
            .sort(
                (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
            );

        return paginate(filteredPosts, {
            params: { lang },
            pageSize: 5,
        });
    });
}

interface Props {
    page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const { lang } = Astro.params as { lang: "en" | "es" };

// Redirect page 1 to the index to avoid duplicate content
if (page.currentPage === 1) {
    return Astro.redirect(`/${lang}/blog/`);
}

const prevUrl =
    page.url.prev === `/${lang}/blog/1` ? `/${lang}/blog/` : page.url.prev;
---

<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead
            title={`Blog — Page ${page.currentPage} — ${SITE_TITLE}`}
            description={SITE_DESCRIPTION}
        />
    </head>
    <body>
        <Header />
        <main>
            <BlogList
                posts={page.data}
                currentPage={page.currentPage}
                totalPages={page.lastPage}
                prevUrl={prevUrl}
                nextUrl={page.url.next}
                lang={lang}
            />
        </main>
        <Footer />
    </body>
</html>

<style>
    main {
        background: var(--paper);
        min-height: 100vh;
    }
</style>
